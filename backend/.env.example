# LLM API configuration
GEMINI_API_KEY=your-gemini-api-key
HF_TOKEN=your-huggingface-token
GRAPHRAG_LLM_PROVIDER=gemini

# TigerGraph Savanna / workspace configuration
# Recommended for Savanna: create an API token and use TG_AUTH_MODE=token.
TG_HOST=https://your-tigergraph-workspace.i.tgcloud.io
TG_HOSTNAME=https://your-tigergraph-workspace.i.tgcloud.io
TG_GRAPH_NAME=MyGraph
TG_GRAPH=MyGraph
TG_AUTH_MODE=token
TG_USERNAME=
TG_PASSWORD=
TG_SECRET=
TG_API_TOKEN=your-savanna-api-token
TG_RESTPP_PORT=14240
TG_GSQL_PORT=14240
TG_SSL_PORT=14240
TG_USE_CLOUD=true

# Optional official TigerGraph GraphRAG service integration
GRAPHRAG_SERVICE_ENABLED=false
GRAPHRAG_SERVICE_URL=http://localhost:8000
GRAPHRAG_SERVICE_GRAPH=MyGraph
GRAPHRAG_SERVICE_AUTH_MODE=basic
GRAPHRAG_SERVICE_USERNAME=
GRAPHRAG_SERVICE_PASSWORD=
GRAPHRAG_SERVICE_API_TOKEN=
GRAPHRAG_SERVICE_TIMEOUT_S=90
GRAPHRAG_SERVICE_RAG_METHOD=
GRAPHRAG_DIRECT_FALLBACK=true

# Local app configuration
BACKEND_PORT=8080
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CHROMA_PERSIST_PATH=./data/chroma_db
DEFAULT_TOP_K=5
DEFAULT_NUM_HOPS=2
